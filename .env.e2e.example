# Copy this file to .env.e2e.local and replace each value with an absolute path.
# .env.e2e.local is intentionally ignored by Git.

STABILIZER_FCP_HELPER=/absolute/path/to/fcp_stabilizer_shortcuts.applescript
STABILIZER_E2E_LIBRARY=/absolute/path/to/stabilizer_super_smoother.fcpbundle
STABILIZER_UI_TEST_LIBRARY=/absolute/path/to/stab-test.fcpbundle
STABILIZER_UI_TEST_EVENT=6-17-26

# Optional. The default is /tmp/stabilizer_e2e.
# STABILIZER_E2E_ARTIFACT_DIR=/absolute/path/to/e2e-artifacts
